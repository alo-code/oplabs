# Copy to .env and fill in. Never commit .env (see .gitignore).
# The working slice (weekly exec brief) needs a real data source + a model key.

# --- Model provider (pick one; the exec-brief slice uses Anthropic by default) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- GitHub connector (the exec-brief slice's real, non-mocked data source) ---
# A classic or fine-grained PAT with read access. Public repos work without a token
# but are rate-limited; a token is recommended.
GITHUB_TOKEN=
# Comma-separated owner/repo targets the brief should cover, e.g. ethereum-optimism/optimism
GITHUB_REPOS=ethereum-optimism/optimism

# --- Optional second source (Notion) — wired in a later slice ---
# NOTION_API_KEY=

# --- Shared memory (optional in crawl stage; Postgres in walk stage) ---
# DATABASE_URL=postgres://localhost:5432/beacon

# --- Runtime ---
LOG_LEVEL=info
BEACON_ENV=local
