# Copy to .env and fill in. Never commit .env (see .gitignore).
# The working slice (weekly exec brief) needs a real data source + a model key.

# --- Model provider (pick one; the exec-brief slice uses Anthropic by default) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- GitHub connector (the exec-brief slice's real, non-mocked data source) ---
# A classic or fine-grained PAT with read access. Public repos work without a token
# but are rate-limited; a token is recommended.
GITHUB_TOKEN=
# Comma-separated owner/repo targets the brief should cover (fanned out one-per-repo),
# e.g. ethereum-optimism/optimism,ethereum-optimism/op-geth
GITHUB_REPOS=ethereum-optimism/optimism

# --- n8n workflow source targets (no ids are baked into exec-brief.json) ---
# In n8n.cloud these go in Settings → Variables/Env; mirrored here for local reference.
# Notion: the database id the integration is shared with.
# NOTION_DATABASE_ID=
# Slack: the one channel to read, + your *.slack.com subdomain for clickable permalinks.
# SLACK_CHANNEL_ID=
# SLACK_WORKSPACE=
# Google Drive: the one folder to scan.
# GDRIVE_FOLDER_ID=
# Calendar (stub): calendar id to read (defaults to 'primary' when enabled).
# GCAL_ID=

# --- Source credential keys (set the credentials INSIDE n8n, not here) ---
# The n8n nodes use n8n-managed credentials (Slack OAuth2, Notion token, Drive OAuth2).
# These vars are only for any local/TS use of the same sources.
# NOTION_API_KEY=
# SLACK_BOT_TOKEN=

# --- Shared memory (optional in crawl stage; Postgres in walk stage) ---
# DATABASE_URL=postgres://localhost:5432/beacon

# --- Runtime ---
LOG_LEVEL=info
BEACON_ENV=local
